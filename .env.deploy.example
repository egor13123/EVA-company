# Sprinthost deploy config. Copy this file to .env.deploy.local and fill in
# real values. .env.deploy.local is gitignored.

# SSH host of the Sprinthost server (from cPanel/ISP panel "SSH/FTP access").
# Example: ch-s1.sprinthost.ru
SPRINTHOST_HOST=

# SSH user (usually your hosting account login, e.g. uXXXXXX or your login).
SPRINTHOST_USER=

# SSH port. Sprinthost default is 22.
SPRINTHOST_PORT=22

# Absolute path to the public directory of eva-tsk.ru on the server.
# Typical Sprinthost layouts:
#   /home/<user>/eva-tsk.ru/public_html
#   /home/<user>/domains/eva-tsk.ru/public_html
# Do NOT point this at /, /home, or your home root — the script will refuse.
SPRINTHOST_PATH=
